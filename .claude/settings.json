{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Bash(git add -A *)",
      "Bash(git add . *)",
      "Bash(git add --all *)",
      "Bash(git push *)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(pkill *)",
      "Bash(kill *)"
    ],
    "allow": [
      "Bash(node --check *)",
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(tail *)",
      "Bash(cat data/*.log)",
      "Bash(wc *)",
      "Bash(curl http://localhost:3200/*)"
    ]
  }
}
